# LiveKit Cloud credentials (https://cloud.livekit.io/)
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# xAI (Grok) API key (https://console.x.ai/)
XAI_API_KEY=your_xai_api_key

# xAI model to use (default: grok-3)
XAI_MODEL=grok-3

# OpenAI API key — used for Whisper STT and TTS
OPENAI_API_KEY=your_openai_api_key

# OpenAI TTS model (default: tts-1) and voice (default: alloy)
# Voice options: alloy, echo, fable, onyx, nova, shimmer
OPENAI_TTS_MODEL=tts-1
OPENAI_TTS_VOICE=alloy
