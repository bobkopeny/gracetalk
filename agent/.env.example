# LiveKit Cloud credentials (https://cloud.livekit.io/)
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# xAI (Grok) API key (https://console.x.ai/)
XAI_API_KEY=your_xai_api_key

# xAI model to use (default: grok-3)
XAI_MODEL=grok-3

# Deepgram API key (https://console.deepgram.com/)
DEEPGRAM_API_KEY=your_deepgram_api_key

# Deepgram TTS voice model (default: aura-asteria-en)
# Other options: aura-luna-en, aura-stella-en, aura-zeus-en
DEEPGRAM_TTS_MODEL=aura-asteria-en
