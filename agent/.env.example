# LiveKit Cloud credentials (https://cloud.livekit.io/)
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# xAI Grok Realtime Voice API (https://console.x.ai/)
XAI_API_KEY=your_xai_api_key

# Grok realtime model (default: grok-2-realtime)
XAI_REALTIME_MODEL=grok-2-realtime

# Voice for the persona (options: Eve, Ara, Rex, Sal, Leo)
XAI_VOICE=Eve

# GraceTalk app callback
GRACETALK_API_URL=https://gracetalk-production.up.railway.app
GRACETALK_AGENT_SECRET=your_shared_secret
